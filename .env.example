# ---- CupidList environment variables ----
# Copy to ".env.local" for local dev, or set these in your Vercel project.
# All of these are OPTIONAL: without them the app runs as a guest experience
# (Local Storage only). Add a provider's keys to enable "Sign in with <it>".
#
# A sign-in button auto-appears for EACH provider you configure below — no
# extra flag needed. Each redirect URL is <your-domain>/api/auth/callback/<id>.

# Required by Auth.js to sign session tokens (needed for any provider).
# Generate one with:  openssl rand -base64 32
AUTH_SECRET=

# LinkedIn — https://www.linkedin.com/developers/apps
# Add the "Sign In with LinkedIn using OpenID Connect" product.
# Redirect URL: <your-domain>/api/auth/callback/linkedin
AUTH_LINKEDIN_ID=
AUTH_LINKEDIN_SECRET=

# Google — https://console.cloud.google.com/apis/credentials
# Create an "OAuth client ID" (Web application).
# Redirect URL: <your-domain>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# Facebook — https://developers.facebook.com/apps (add "Facebook Login")
# Redirect URL: <your-domain>/api/auth/callback/facebook
AUTH_FACEBOOK_ID=
AUTH_FACEBOOK_SECRET=

# ---- Per-user cloud sync (Supabase) ----
# When configured, a signed-in user's friends + matches are stored server-side
# and follow them across devices. Without these, the app uses Local Storage.
#
# Create a free project at https://supabase.com, run supabase/schema.sql in its
# SQL editor, then copy these from Project Settings → API:
#   SUPABASE_URL                = Project URL
#   SUPABASE_SERVICE_ROLE_KEY   = service_role secret  (SERVER ONLY — never public)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Flip to "true" once Supabase + LinkedIn login are configured to turn on
# per-user cloud sync. Public by design.
NEXT_PUBLIC_CLOUD_SYNC=false
